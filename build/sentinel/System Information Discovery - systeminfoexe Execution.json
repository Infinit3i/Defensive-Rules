{
  "kind": "Scheduled",
  "properties": {
    "displayName": "System Information Discovery - systeminfoexe Execution",
    "description": "Detect execution of systeminfo.exe which is often used by attackers to enumerate OS and patch-level information.",
    "severity": "Medium",
    "enabled": false,
    "query": "Event\n| where TimeGenerated > ago(24h)\n| where Image endswith \"\\systeminfo.exe\" and (CommandLine|contains has \"systeminfo\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "a8f3f9d6-9b2b-4f0d-8f2c-1c2e0a9b7f01",
      "SigmaLevel": "medium",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/10/19"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [
      "Discovery"
    ],
    "techniques": [
      "T1082"
    ]
  }
}