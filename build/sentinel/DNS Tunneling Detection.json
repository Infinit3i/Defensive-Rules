{
  "kind": "Scheduled",
  "properties": {
    "displayName": "DNS Tunneling Detection",
    "description": "Detects potential DNS tunneling by identifying long or high-frequency DNS queries, especially those using NULL or TXT query types, which are commonly abused for data exfiltration or C2.",
    "severity": "High",
    "enabled": false,
    "query": "DnsEvents\n| where TimeGenerated > ago(24h)\n| where (qtype_name|contains has \"TXT\" or qtype_name|contains has \"NULL\") and query matches regex \".{50,}\"",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "123fabc4-5678-4def-9876-a1b2c3d4e5f6",
      "SigmaLevel": "high",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/04/08"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [],
    "techniques": [
      "T004"
    ]
  }
}