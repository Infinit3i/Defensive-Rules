{
  "kind": "Scheduled",
  "properties": {
    "displayName": "FTP or anonymous file transfer indicators ftp ftps smb file transfer",
    "description": "Detect FTP activity, SMB file copy events, or anonymous uploads/downloads that indicate tools being brought into the environment via legacy protocols (ftp/ftps, smb put/get).",
    "severity": "Medium",
    "enabled": false,
    "query": "union SecurityEvent, Event\n| where TimeGenerated > ago(24h)\n| where (zeek.smb.command|contains has \"NT_CREATE_ANDX\" or zeek.smb.command|contains has \"SMB_COM_WRITE\") and (zeek.ftp.request|contains has \"STOR\" or zeek.ftp.request|contains has \"PUT\" or zeek.ftp.request|contains has \"anonymous\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "d1105a01-0005-4c11-8a05-000000000005",
      "SigmaLevel": "medium",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/10/19"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [
      "CommandAndControl"
    ],
    "techniques": [
      "T1105"
    ]
  }
}