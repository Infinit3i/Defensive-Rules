{
  "kind": "Scheduled",
  "properties": {
    "displayName": "Timeout  choice based long delays in cmdbatch",
    "description": "Detect use of `timeout`, `choice` or other cmd-based delay constructs with long durations frequently used to bypass sandbox time windows.",
    "severity": "Medium",
    "enabled": false,
    "query": "Event\n| where TimeGenerated > ago(24h)\n| where Image endswith \"\\cmd.exe\" and (CommandLine|contains has \"timeout /t 60\" or CommandLine|contains has \"timeout /t 300\" or CommandLine|contains has \"choice /t 60\" or CommandLine|contains has \"choice /t 300\") and Image endswith \"\\cmd.exe\" and (CommandLine|contains has \"ping -n 60 127.0.0.1\" or CommandLine|contains has \"ping -n 300 127.0.0.1\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "7a0c3e2b-4d5f-4e6a-8b9c-1d2e3f4a5b6c",
      "SigmaLevel": "medium",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/10/19"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [],
    "techniques": [
      "T003"
    ]
  }
}