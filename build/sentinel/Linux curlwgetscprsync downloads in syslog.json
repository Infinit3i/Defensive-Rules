{
  "kind": "Scheduled",
  "properties": {
    "displayName": "Linux curlwgetscprsync downloads in syslog",
    "description": "Detect use of curl, wget, scp, sftp or rsync to retrieve files from remote hosts recorded in syslog/audit \u2014 common ingress tool transfer on Linux hosts.",
    "severity": "High",
    "enabled": false,
    "query": "Syslog\n| where TimeGenerated > ago(24h)\n| where (Message|contains has \"curl -O\" or Message|contains has \"curl -o\" or Message|contains has \"wget \" or Message|contains has \"scp \" or Message|contains has \"sftp \" or Message|contains has \"rsync \") and (Message|contains has \"/tmp/\" or Message|contains has \"/var/tmp/\" or Message|contains has \"/home/\" or Message|contains has \"/dev/shm/\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "d1105a01-0004-4c11-8a05-000000000004",
      "SigmaLevel": "high",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/10/19"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [
      "CommandAndControl"
    ],
    "techniques": [
      "T1105"
    ]
  }
}