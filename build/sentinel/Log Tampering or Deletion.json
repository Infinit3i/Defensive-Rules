{
  "kind": "Scheduled",
  "properties": {
    "displayName": "Log Tampering or Deletion",
    "description": "Detects potential log tampering or deletion on Linux systems by monitoring syslog events for suspicious commands or messages (e.g. 'rm -rf /var/log', 'deleted log', 'truncated log', 'log cleared') that may indicate attempts to remove or obscure log data.",
    "severity": "Medium",
    "enabled": false,
    "query": "Syslog\n| where TimeGenerated > ago(24h)\n| where (Message|contains has \"rm -rf /var/log\" or Message|contains has \"rm -f /var/log\" or Message|contains has \"deleted log\" or Message|contains has \"truncated log\" or Message|contains has \"log cleared\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "9d2f1c73-6f4e-4b2a-bd33-1234567890ab",
      "SigmaLevel": "medium",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/04/08"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [],
    "techniques": [
      "T1070"
    ]
  }
}