{
  "kind": "Scheduled",
  "properties": {
    "displayName": "Find_and_ls_recursive_unix_syslog",
    "description": "Detect Unix/Linux file and directory discovery via auditd/syslog commands such as find / -type f, ls -R, tree or recursive locate usage recorded in syslog/audit.",
    "severity": "Medium",
    "enabled": false,
    "query": "Syslog\n| where TimeGenerated > ago(24h)\n| where (Message|contains has \"find / -type f\" or Message|contains has \"find / -name\" or Message|contains has \"find . -type f -name\") and (Message|contains has \"ls -R\" or Message|contains has \"ls -laR\" or Message|contains has \"tree \") and (Message|contains has \"updatedb\" or Message|contains has \"locate \")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
