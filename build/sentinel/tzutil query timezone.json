{
  "kind": "Scheduled",
  "properties": {
    "displayName": "tzutil query timezone",
    "description": "Detects use of tzutil to query or set the system timezone which may indicate system time discovery or manipulation.",
    "severity": "Low",
    "enabled": false,
    "query": "Event\n| where TimeGenerated > ago(24h)\n| where Image endswith \"\\tzutil.exe\" and (CommandLine|contains has \" /g\" or CommandLine|contains has \" /s \" or CommandLine|contains has \" /l\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
