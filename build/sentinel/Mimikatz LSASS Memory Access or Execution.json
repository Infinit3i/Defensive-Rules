{
  "kind": "Scheduled",
  "properties": {
    "displayName": "Mimikatz LSASS Memory Access or Execution",
    "description": "Detects access to lsass.exe memory or usage of common Mimikatz commands like sekurlsa or logonpasswords.",
    "severity": "High",
    "enabled": false,
    "query": "Event\n| where TimeGenerated > ago(24h)\n| where (EventID == \"1\" or EventID == \"10\") and TargetImage endswith \"\\lsass.exe\" and (CommandLine|contains has \"sekurlsa\" or CommandLine|contains has \"logonpasswords\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "2b8f9c1b-7a8e-4f02-9563-7d11fa0df8aa",
      "SigmaLevel": "high",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/04/20"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [],
    "techniques": [
      "T001"
    ]
  }
}