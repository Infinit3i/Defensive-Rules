{
  "kind": "Scheduled",
  "properties": {
    "displayName": "Long delay in compiled binaries via Sleep or NtDelayExecution",
    "description": "Detect process creations of binaries whose commandline, scriptblock, or loaded modules contain Sleep calls, NtDelayExecution, or suspicious long-wait logic often used to evade sandbox runtime limits.",
    "severity": "High",
    "enabled": false,
    "query": "Event\n| where TimeGenerated > ago(24h)\n| where (CommandLine|contains has \"sleep(\" or CommandLine|contains has \"Sleep(\" or CommandLine|contains has \"NtDelayExecution\" or CommandLine|contains has \"NtDelayExecution(\") and (TargetFilename|contains has \"\\Temp\\\" or TargetFilename|contains has \"\\AppData\\\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
