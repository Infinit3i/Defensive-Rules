{
  "kind": "Scheduled",
  "properties": {
    "displayName": "Abnormal User Account Modifications",
    "description": "Detects abnormal modifications to user accounts, such as creation, modification, or deletion, that may indicate unauthorized account manipulation.",
    "severity": "Medium",
    "enabled": false,
    "query": "Syslog\n| where TimeGenerated > ago(24h)\n| where (Message|contains has \"useradd\" or Message|contains has \"usermod\" or Message|contains has \"userdel\" or Message|contains has \"groupadd\" or Message|contains has \"groupdel\" or Message|contains has \"passwd: password changed\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "e8b3fa21-9d45-4c2a-90d7-1234567890ab",
      "SigmaLevel": "medium",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/04/08"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [],
    "techniques": [
      "T1098"
    ]
  }
}