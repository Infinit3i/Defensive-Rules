{
  "kind": "Scheduled",
  "properties": {
    "displayName": "w32tm query or status checks",
    "description": "Detects w32tm queries and status commands used to inspect Windows time service configuration and synchronization state.",
    "severity": "Medium",
    "enabled": false,
    "query": "Event\n| where TimeGenerated > ago(24h)\n| where Image endswith \"\\w32tm.exe\" and (CommandLine|contains has \"/query\" or CommandLine|contains has \"/status\" or CommandLine|contains has \"/stripchart\") and Image endswith \"\\cmd.exe\" and (CommandLine|contains has \"w32tm /query\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "2a3b4c5d-6e7f-8901-2345-6789abcdef01",
      "SigmaLevel": "medium",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/10/19"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [],
    "techniques": [
      "T1124"
    ]
  }
}