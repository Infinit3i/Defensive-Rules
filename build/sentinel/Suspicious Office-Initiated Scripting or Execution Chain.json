{
  "kind": "Scheduled",
  "properties": {
    "displayName": "Suspicious Office-Initiated Scripting or Execution Chain",
    "description": "Detects suspicious parent-child chains such as Office apps spawning script interpreters like powershell.exe, mshta.exe, etc., based on Sysmon Event ID 1.",
    "severity": "High",
    "enabled": false,
    "query": "Event\n| where TimeGenerated > ago(24h)\n| where (ParentImage|endswith has \"\\winword.exe\" or ParentImage|endswith has \"\\excel.exe\" or ParentImage|endswith has \"\\outlook.exe\") and (Image|endswith has \"\\powershell.exe\" or Image|endswith has \"\\mshta.exe\" or Image|endswith has \"\\cmd.exe\" or Image|endswith has \"\\wscript.exe\" or Image|endswith has \"\\cscript.exe\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "6df2e2b1-14db-4fc7-9759-8869c8d3e1d9",
      "SigmaLevel": "high",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/04/20"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [
      "Execution"
    ],
    "techniques": [
      "T1059",
      "T001",
      "T1218"
    ]
  }
}