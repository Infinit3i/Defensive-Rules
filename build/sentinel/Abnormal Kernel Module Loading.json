{
  "kind": "Scheduled",
  "properties": {
    "displayName": "Abnormal Kernel Module Loading",
    "description": "Detects potential abnormal kernel module loading on Linux systems by monitoring syslog messages for module load commands (e.g., insmod, modprobe) executed from non-standard directories such as /tmp/.",
    "severity": "Medium",
    "enabled": false,
    "query": "Syslog\n| where TimeGenerated > ago(24h)\n| where (Message|contains has \"insmod\" or Message|contains has \"modprobe\") and Message contains \"/tmp/\"",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "2f7e9d45-8c3a-4d5e-bf90-1234567890ab",
      "SigmaLevel": "medium",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/04/08"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [],
    "techniques": [
      "T007"
    ]
  }
}