{
  "kind": "Scheduled",
  "properties": {
    "displayName": "WebDAV_PROPFIND_Directory_Enumeration_Zeek",
    "description": "Detect WebDAV/HTTP directory enumeration via PROPFIND requests and directory traversal-like URIs (Depth header, PROPFIND method) observed in Zeek/HTTP logs indicating remote directory discovery.",
    "severity": "Medium",
    "enabled": false,
    "query": "union SecurityEvent, Event\n| where TimeGenerated > ago(24h)\n| where (zeek.http.method|contains has \"PROPFIND\") and (zeek.http.headers|contains has \"Depth: 1\" or zeek.http.headers|contains has \"Depth: infinity\") and (zeek.http.uri|matches has \"^/.*(/|%2F).*\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "3c4d5e6f-7081-92a0-b1c2-3d4e5f6a7b8c",
      "SigmaLevel": "medium",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/10/19"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [],
    "techniques": [
      "T1083"
    ]
  }
}