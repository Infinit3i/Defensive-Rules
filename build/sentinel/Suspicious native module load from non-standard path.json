{
  "kind": "Scheduled",
  "properties": {
    "displayName": "Suspicious native module load from non-standard path",
    "description": "Detect processes loading native modules (DLLs) from unexpected or user-writable locations (AppData, Temp, user profile paths) which may indicate custom native API usage or dropped native helpers.",
    "severity": "High",
    "enabled": false,
    "query": "Event\n| where TimeGenerated > ago(24h)\n| where (Image|endswith has \"\\rundll32.exe\" or Image|endswith has \"\\svchost.exe\" or Image|endswith has \"\\explorer.exe\") and (TargetFilename|contains has \"\\AppData\\\" or TargetFilename|contains has \"\\Local\\Temp\\\" or TargetFilename|contains has \"\\Temp\\\" or TargetFilename|contains has \"\\Users\\\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "4c9e5a2b-6d3f-4e56-8a7b-1f2e3d4c5b6a",
      "SigmaLevel": "high",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/10/19"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [
      "Execution"
    ],
    "techniques": [
      "T1106"
    ]
  }
}