{
  "kind": "Scheduled",
  "properties": {
    "displayName": "Suspicious WMI-Based Execution Wmiprvse Spawning Scripting Engines",
    "description": "Detects suspicious use of WMI where wmiprvse.exe spawns PowerShell, cmd.exe, or other scripting engines.",
    "severity": "High",
    "enabled": false,
    "query": "Event\n| where TimeGenerated > ago(24h)\n| where (EventID == \"1\" or EventID == \"3\") and ParentImage endswith \"\\wmiprvse.exe\" and (Image|endswith has \"\\powershell.exe\" or Image|endswith has \"\\cmd.exe\" or Image|endswith has \"\\mshta.exe\" or Image|endswith has \"\\wscript.exe\" or Image|endswith has \"\\cscript.exe\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "c682cb7c-7231-45a4-89ec-5ee6894c14cc",
      "SigmaLevel": "high",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/04/20"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [],
    "techniques": [
      "T1047"
    ]
  }
}