{
  "kind": "Scheduled",
  "properties": {
    "displayName": "Start-Sleep long duration in PowerShell",
    "description": "Detect PowerShell scriptblocks using Start-Sleep with unusually long durations commonly used to evade sandbox analysis.",
    "severity": "Medium",
    "enabled": false,
    "query": "Event\n| where TimeGenerated > ago(24h)\n| where (ScriptBlockText|contains has \"Start-Sleep -Seconds 60\" or ScriptBlockText|contains has \"Start-Sleep -Seconds 120\" or ScriptBlockText|contains has \"Start-Sleep -Seconds 300\" or ScriptBlockText|contains has \"Start-Sleep -Seconds 600\" or ScriptBlockText|contains has \"Start-Sleep -Seconds 900\") and (ScriptBlockText|contains has \"Start-Sleep -s 60\" or ScriptBlockText|contains has \"Start-Sleep -s 300\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "6f9b2d1a-3c4e-4f5b-9a7c-0b1d2e3f4a5b",
      "SigmaLevel": "medium",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/10/19"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [],
    "techniques": [
      "T003"
    ]
  }
}