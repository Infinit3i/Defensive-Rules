{
  "kind": "Scheduled",
  "properties": {
    "displayName": "Suspicious HTTP User-Agent Strings",
    "description": "Detects suspicious or malicious HTTP User-Agent strings observed in Zeek HTTP logs, which may indicate malware beaconing, automated tools, or penetration testing frameworks.",
    "severity": "Medium",
    "enabled": false,
    "query": "CommonSecurityLog\n| where TimeGenerated > ago(24h)\n| where (user_agent|contains has \"curl/\" or user_agent|contains has \"python-requests\" or user_agent|contains has \"powershell\" or user_agent|contains has \"Go-http-client\" or user_agent|contains has \"wget\" or user_agent|contains has \"nmap\" or user_agent|contains has \"sqlmap\" or user_agent|contains has \"fuzz\" or user_agent|contains has \"bot\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "f2c1a8b9-d456-4e7c-8123-abcdef987654",
      "SigmaLevel": "medium",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/04/08"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [],
    "techniques": [
      "T001"
    ]
  }
}