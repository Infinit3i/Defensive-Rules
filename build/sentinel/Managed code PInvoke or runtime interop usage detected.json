{
  "kind": "Scheduled",
  "properties": {
    "displayName": "Managed code PInvoke or runtime interop usage detected",
    "description": "Detect managed (.NET) applications or scripts that declare P/Invoke signatures, use Runtime.InteropServices or Marshal methods to call native APIs (indicative of Native API usage).",
    "severity": "High",
    "enabled": false,
    "query": "Event\n| where TimeGenerated > ago(24h)\n| where (CommandLine|contains has \"Add-Type\" or CommandLine|contains has \"System.Runtime.InteropServices\" or CommandLine|contains has \"PInvoke\") and Image endswith \"\\dotnet.exe\" and (CommandLine|contains has \"DllImport\" or CommandLine|contains has \"Marshal.\")",
    "queryFrequency": "PT15M",
    "queryPeriod": "PT24H",
    "triggerOperator": "GreaterThan",
    "triggerThreshold": 0,
    "suppressionDuration": "PT1H",
    "suppressionEnabled": false,
    "alertRuleTemplateName": null,
    "incidentConfiguration": {
      "createIncident": true,
      "groupingConfiguration": {
        "enabled": false,
        "reopenClosedIncident": false,
        "lookbackDuration": "PT5H",
        "matchingMethod": "AllEntities",
        "groupByEntities": [],
        "groupByAlertDetails": [],
        "groupByCustomDetails": []
      }
    },
    "eventGroupingSettings": {
      "aggregationKind": "SingleAlert"
    },
    "alertDetailsOverride": null,
    "customDetails": {
      "SigmaRuleId": "6e1a7c4d-9f5b-4g78-0h9i-3c4d5e6f7a8b",
      "SigmaLevel": "high",
      "SigmaAuthor": "Matthew Iverson",
      "SigmaDate": "2025/10/19"
    },
    "entityMappings": [
      {
        "entityType": "Account",
        "fieldMappings": [
          {
            "identifier": "Name",
            "columnName": "Account"
          }
        ]
      },
      {
        "entityType": "Host",
        "fieldMappings": [
          {
            "identifier": "HostName",
            "columnName": "Computer"
          }
        ]
      }
    ],
    "sentinelEntitiesMappings": null,
    "templateVersion": null,
    "tactics": [
      "Execution"
    ],
    "techniques": [
      "T1106"
    ]
  }
}